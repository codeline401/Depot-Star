generator client {
    provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url      = env("DATABASE_URL")
  // uncomment next line if you use Prisma <5.10
  // directUrl = env("DATABASE_URL_UNPOOLED")
}

enum UserRole {
    ADMIN 
    SELLER
}

enum BottleType {
    PLASTIQUE
    VERRE
}

enum EmballageType {
    BOUTEILLE
    CAGEOT
}

model User {
    id Int @id @default(autoincrement())
    nom String
    prenom String
    alias String @unique
    mdp String // Stockage du mot de passe haché
    role UserRole @default(SELLER)
    mustChangePassword Boolean @default(true) // Indique si l'utilisateur doit changer son mot de passe à la première connexion
}

model Fournisseur {
    id Int @id @default(autoincrement())
    nom String
    adresse String
    telephone String
    listeArticles Article[] // Relation avec les articles fournis
}

model Article{
    id Int @id @default(autoincrement())
    nom String
    prix Float
    quantitéStock Int
    bottleType BottleType
    aConsigner Boolean @default(false)
    prixConsigne Float @default(0) // Prix de consignation propre à chaque article
    fournisseurId Int
    fournisseur Fournisseur @relation(fields: [fournisseurId], references: [id]) // Relation avec le fournisseur
}

model Client {
    id Int @id @default(autoincrement())
    nom String
    adresse String
    telephone String
    ventes Vente[]
}

model Vente {
    id Int @id @default(autoincrement())
    date DateTime @default(now())
    total Float
    consigneRendue Float @default(0)
    consigneCageotRendue Float @default(0) // Montant total des consignes cageot rendues
    vendeur String
    clientId Int
    client Client @relation(fields: [clientId], references: [id])
    lignes VenteLigne[]
    consignesRetour ConsigneRetour[]
    cageotsRetour CageotRetour[]
}

model ConsigneRetour {
    id Int @id @default(autoincrement())
    venteId Int
    vente Vente @relation(fields: [venteId], references: [id])
    articleId Int // snapshot
    articleNom String
    prixConsigne Float
    quantite Int
    montant Float
}

model VenteLigne {
    id Int @id @default(autoincrement())
    venteId Int
    vente Vente @relation(fields: [venteId], references: [id])
    articleId Int
    articleNom String
    prixUnitaire Float
    prixConsigne Float // 0 si non consigné (consigne bouteille)
    consigneCageot Float @default(0) // consigne cageot totale pour cette ligne
    qteCageots Int @default(0) // nombre de cageots utilisés
    quantite Int
    prixTotal Float
}

model CageotRetour {
    id Int @id @default(autoincrement())
    venteId Int
    vente Vente @relation(fields: [venteId], references: [id])
    capacite Int // capacite du cageot (12, 20 ou 24)
    quantite Int
    montant Float // quantite * 8000
}

model Emballage {
    id            Int           @id @default(autoincrement())
    type          EmballageType
    prixConsigne  Float         // 300/500/700 pour bouteilles, 8000 pour cageots
    capacite      Int           @default(0) // Nb de bouteilles par cageot (0 pour les bouteilles)
    quantiteStock Int           @default(0)

    @@unique([type, prixConsigne, capacite])
}

enum ApproStatus {
    VERIFIE // Liste vérifiée, en attente de validation
    VALIDE  // Marchandises entrées en stock
}

enum MouvementType {
    VENTE       // Sortie de stock suite à une vente
    APPRO       // Entrée de stock suite à une validation d'appro
    CORRECTION  // Ajustement manuel (casse, vol, inventaire physique)
}

// Historique de chaque mouvement de stock par article
model MouvementStock {
    id         Int           @id @default(autoincrement())
    date       DateTime      @default(now())
    articleId  Int
    articleNom String        // snapshot du nom à la date du mouvement
    type       MouvementType
    quantite   Int           // positif = entrée, négatif = sortie
    motif      String?       // obligatoire pour CORRECTION
    refId      Int?          // id de la Vente ou de l'Appro source

    @@index([articleId])
    @@index([type])
}

// Historique des ajustements de stock d'emballage (inventaire physique)
model EmballageMouvement {
    id          Int           @id @default(autoincrement())
    date        DateTime      @default(now())
    emballageId Int
    targetLabel String        // snapshot ex. "BOUTEILLE cap.0" à la date du mouvement
    type        MouvementType
    quantite    Int           // positif = entrée, négatif = sortie
    motif       String?       // obligatoire pour CORRECTION
    refId       Int?          // réservé pour usage futur

    @@index([emballageId])
    @@index([type])
}

// Ordre d'approvisionnement : créé au "checker", validé à l'entrée en stock
model Appro {
    id             Int          @id @default(autoincrement())
    date           DateTime     @default(now())
    dateValidation DateTime?    // renseignée quand status passe à VALIDE
    status         ApproStatus  @default(VERIFIE)
    coutTotal      Float        // Coût total = Σ (qteCommandee × prixUnitaire)
    lignes         ApproLigne[]
}

// Détail ligne par ligne d'un ordre d'appro
model ApproLigne {
    id           Int    @id @default(autoincrement())
    approId      Int
    appro        Appro  @relation(fields: [approId], references: [id])
    articleId    Int    // référence article (non contrainte pour garder la trace si article supprimé)
    articleNom   String // snapshot du nom au moment de l'appro
    prixUnitaire Float  // snapshot du prix d'achat
    qteCommandee Int    // quantité réceptionnée
    coutLigne    Float  // qteCommandee × prixUnitaire
}